# Copy this file to .env and fill in the values after you deploy the contract.

# The deployed Soroban contract id (starts with C...)
VITE_CONTRACT_ID=CA...REPLACE_ME

# Stellar network: TESTNET or PUBLIC
VITE_NETWORK=TESTNET

# Soroban RPC endpoint
VITE_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase for the chosen network
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
